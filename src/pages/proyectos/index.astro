---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import GithubRepos from '../../components/GithubRepos.astro';
import { getFeaturedRepos } from '../../lib/github';

const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const repos = await getFeaturedRepos();
---

<BaseLayout
  title="Proyectos | Lukas Ibáñez"
  description="Casos reales de Lukas Ibáñez: sitios institucionales desde cero, intranets, migraciones de infraestructura, SEO técnico y backends en producción."
  path="/proyectos/"
>
  <section id="projects-page-hero" class="projects-page-hero">
    <div class="projects-page-intro reveal">
      <p class="eyebrow">Proyectos</p>
      <h1>Casos donde importa cerrar bien el ciclo.</h1>
      <p class="projects-page-copy section-copy">
        Trabajo real para instituciones y empresas: desarrollo desde cero, mantención de sitios en producción,
        migraciones de infraestructura y backends. Cuando un proyecto está bajo confidencialidad, describo el
        problema, mi rol y el stack sin exponer material visual.
      </p>
    </div>
  </section>

  <section id="projects" class="projects-grid-section">
    <div class="projects-grid-container">
      <div class="projects-grid">
        {projects.map((project, index) => <ProjectCard project={project} index={index} />)}
      </div>
    </div>
  </section>

  <GithubRepos repos={repos} />
</BaseLayout>

<style>
  .projects-page-hero {
    @apply bg-bg pb-10 pt-20;
  }

  .projects-page-intro {
    @apply mx-auto w-full max-w-4xl px-5 sm:px-8;
  }

  .projects-page-intro h1 {
    @apply mt-4 font-serif text-5xl leading-tight sm:text-7xl;
  }

  .projects-page-copy {
    @apply mt-6;
  }

  .projects-grid-section {
    @apply bg-bg pb-24;
  }

  .projects-grid-container {
    @apply mx-auto w-full max-w-site px-5 sm:px-8;
  }

  .projects-grid {
    @apply grid gap-6 md:grid-cols-2;
  }
</style>
