---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllPosts } from '../../lib/sanity';

const posts = await getAllPosts();
---

<BaseLayout
  title="Blog | Lukas Ibáñez"
  description="Notas técnicas de Lukas Ibáñez sobre desarrollo web, servidores, SEO, performance y decisiones full-stack."
  path="/blog/"
>
  <section id="blog-page" class="blog-page">
    <div class="blog-page-container">
      <div id="blog-page-intro" class="blog-page-intro reveal">
        <p class="eyebrow">Blog</p>
        <h1>Apuntes técnicos para proyectos reales.</h1>
        <p class="blog-page-copy section-copy">
          Notas técnicas sobre desarrollo web, servidores, SEO, performance y decisiones full-stack tomadas en proyectos reales.
        </p>
      </div>

      <div id="blog-post-list" class="blog-post-list">
        {
          posts.length > 0 ? (
            posts.map((post) => (
              <article class="blog-card batch-reveal">
                <div class="blog-tags">
                  {post.tags.map((tag) => <span>{tag}</span>)}
                </div>
                <h2>{post.title}</h2>
                <p class="blog-meta">
                  {post.category && <span>{post.category}</span>}
                  {post.category && ' · '}
                  {new Date(post.publishedAt).toLocaleDateString('es-CL')} · {post.readingTimeLabel}
                </p>
                <p class="blog-excerpt">{post.excerpt}</p>
                <a href={`/blog/${post.slug}/`} class="blog-card-action button-primary">Leer artículo</a>
              </article>
            ))
          ) : (
            <article class="blog-card batch-reveal">
              <p class="eyebrow">Blog</p>
              <h2>Pronto, nuevas notas técnicas.</h2>
              <p class="blog-excerpt">
                Estoy preparando los próximos artículos sobre desarrollo, infraestructura y performance. Vuelve pronto.
              </p>
            </article>
          )
        }
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .blog-page {
    @apply bg-bg py-20;
  }

  .blog-page-container {
    @apply mx-auto w-full max-w-site px-5 sm:px-8;
  }

  .blog-page-intro {
    @apply max-w-4xl;
  }

  .blog-page-intro h1 {
    @apply mt-4 font-serif text-5xl leading-tight sm:text-7xl;
  }

  .blog-page-copy {
    @apply mt-6;
  }

  .blog-post-list {
    @apply mt-12 grid gap-5;
  }

  .blog-card {
    @apply rounded-2xl border border-border bg-surface p-7;
  }

  .blog-card h2 {
    @apply mt-5 font-serif text-3xl;
  }

  .blog-tags {
    @apply flex flex-wrap gap-2;
  }

  .blog-tags span {
    @apply rounded-full bg-accent-soft px-3 py-1 text-xs font-semibold text-text;
  }

  .blog-meta {
    @apply mt-3 text-sm text-text-soft;
  }

  .blog-excerpt {
    @apply mt-4 max-w-3xl leading-7 text-text-soft;
  }

  .blog-card-action {
    @apply mt-6;
  }
</style>
