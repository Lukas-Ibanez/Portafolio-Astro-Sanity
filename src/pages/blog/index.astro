---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllPosts } from '../../lib/sanity';

const posts = await getAllPosts();
---

<BaseLayout
  title="Blog | Lukas Ibáñez"
  description="Notas técnicas de Lukas Ibáñez sobre desarrollo web, servidores, SEO, performance y decisiones full-stack."
  path="/blog/"
>
  <section class="bg-bg py-20">
    <div class="container-site">
      <div class="reveal max-w-4xl">
        <p class="eyebrow">Blog</p>
        <h1 class="mt-4 font-serif text-5xl leading-tight sm:text-7xl">Apuntes técnicos para proyectos reales.</h1>
        <p class="section-copy mt-6">
          El blog se carga desde Sanity durante el build. Si no hay configuración o posts publicados, el sitio sigue compilando.
        </p>
      </div>

      <div class="mt-12 grid gap-5">
        {
          posts.length > 0 ? (
            posts.map((post) => (
              <article class="batch-reveal rounded-2xl border border-border bg-surface p-7">
                <div class="flex flex-wrap gap-2">
                  {post.tags.map((tag) => <span class="rounded-full bg-accent-soft px-3 py-1 text-xs font-semibold text-text">{tag}</span>)}
                </div>
                <h2 class="mt-5 font-serif text-3xl">{post.title}</h2>
                <p class="mt-3 text-sm text-text-soft">
                  {new Date(post.publishedAt).toLocaleDateString('es-CL')} · {post.readingTime} min
                </p>
                <p class="mt-4 max-w-3xl leading-7 text-text-soft">{post.excerpt}</p>
                <a href={`/blog/${post.slug}/`} class="button-primary mt-6">Leer artículo</a>
              </article>
            ))
          ) : (
            <article class="batch-reveal rounded-2xl border border-border bg-surface p-7">
              <p class="eyebrow">TODO Sanity</p>
              <h2 class="mt-4 font-serif text-3xl">Publicar el primer post.</h2>
              <p class="mt-4 max-w-3xl leading-7 text-text-soft">
                Configura `SANITY_PROJECT_ID`, `SANITY_DATASET` y crea documentos `post` en el Studio. El índice se actualizará en el próximo build.
              </p>
            </article>
          )
        }
      </div>
    </div>
  </section>
</BaseLayout>
