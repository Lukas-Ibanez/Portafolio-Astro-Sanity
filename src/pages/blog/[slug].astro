---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllPosts, getPostBySlug } from '../../lib/sanity';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const post = slug ? await getPostBySlug(slug) : null;

if (!post) {
  return Astro.redirect('/blog/');
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  description: post.excerpt,
  datePublished: post.publishedAt,
  author: {
    '@type': 'Person',
    name: 'Lukas Ibáñez',
  },
};
---

<BaseLayout
  title={post.seo?.title || `${post.title} | Lukas Ibáñez`}
  description={post.seo?.description || post.excerpt}
  path={`/blog/${post.slug}/`}
  type="article"
  jsonLd={jsonLd}
>
  <article id="blog-post" class="blog-post">
    <div class="blog-post-container">
      <div id="blog-post-header" class="blog-post-header reveal">
        <div class="blog-post-tags">
          {post.tags.map((tag) => <span>{tag}</span>)}
        </div>
        <h1>{post.title}</h1>
        <p class="blog-post-meta">
          {new Date(post.publishedAt).toLocaleDateString('es-CL')} · {post.readingTime} min de lectura
        </p>
        <p class="blog-post-excerpt">{post.excerpt}</p>
      </div>

      <div id="blog-post-body" class="article-body blog-post-body" set:html={post.bodyHtml} />
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post {
    @apply bg-bg py-20;
  }

  .blog-post-container {
    @apply mx-auto w-full max-w-3xl px-5 sm:px-8;
  }

  .blog-post-tags {
    @apply flex flex-wrap gap-2;
  }

  .blog-post-tags span {
    @apply rounded-full bg-accent-soft px-3 py-1 text-xs font-semibold text-text;
  }

  .blog-post-header h1 {
    @apply mt-6 font-serif text-5xl leading-tight sm:text-6xl;
  }

  .blog-post-meta {
    @apply mt-5 text-sm text-text-soft;
  }

  .blog-post-excerpt {
    @apply mt-7 text-xl leading-8 text-text-soft;
  }

  .blog-post-body {
    @apply mt-12;
  }
</style>
