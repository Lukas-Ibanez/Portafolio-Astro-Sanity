---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getAllPosts, getPostBySlug } from '../../lib/sanity';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post, index) => ({
    params: { slug: post.slug },
    props: {
      // Posts are ordered newest → oldest.
      newer: index > 0 ? { slug: posts[index - 1].slug, title: posts[index - 1].title } : null,
      older: index < posts.length - 1 ? { slug: posts[index + 1].slug, title: posts[index + 1].title } : null,
    },
  }));
}

const { slug } = Astro.params;
const { newer, older } = Astro.props;
const post = slug ? await getPostBySlug(slug) : null;

if (!post) {
  return Astro.redirect('/blog/');
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  description: post.excerpt,
  datePublished: post.publishedAt,
  author: {
    '@type': 'Person',
    name: 'Lukas Ibáñez',
  },
};
---

<BaseLayout
  title={post.seo?.title || `${post.title} | Lukas Ibáñez`}
  description={post.seo?.description || post.excerpt}
  path={`/blog/${post.slug}/`}
  type="article"
  jsonLd={jsonLd}
>
  <article id="blog-post" class="blog-post">
    <div class="blog-post-container">
      <div id="blog-post-header" class="blog-post-header reveal">
        <div class="blog-post-tags">
          {post.tags.map((tag) => <span>{tag}</span>)}
        </div>
        <h1>{post.title}</h1>
        <p class="blog-post-meta">
          {post.category && <span>{post.category}</span>}
          {post.category && ' · '}
          {new Date(post.publishedAt).toLocaleDateString('es-CL')} · {post.readingTimeLabel} de lectura
        </p>
        <p class="blog-post-excerpt">{post.excerpt}</p>
      </div>

      <div id="blog-post-body" class="article-body blog-post-body" set:html={post.bodyHtml} />

      {
        post.sources.length > 0 && (
          <aside class="blog-post-sources" aria-label="Fuentes del artículo">
            <h2>Fuentes</h2>
            <ul>
              {post.sources.map((source) => (
                <li>
                  <a href={source.url} target="_blank" rel="noreferrer noopener">{source.title}</a>
                </li>
              ))}
            </ul>
          </aside>
        )
      }

      {
        (newer || older) && (
          <nav class="blog-post-nav" aria-label="Navegación entre artículos">
            {older ? (
              <a class="blog-post-nav-link" href={`/blog/${older.slug}/`}>
                <span>← Anterior</span>
                <strong>{older.title}</strong>
              </a>
            ) : (
              <span />
            )}
            {newer && (
              <a class="blog-post-nav-link blog-post-nav-next" href={`/blog/${newer.slug}/`}>
                <span>Siguiente →</span>
                <strong>{newer.title}</strong>
              </a>
            )}
          </nav>
        )
      }
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post {
    @apply bg-bg py-20;
  }

  .blog-post-container {
    @apply mx-auto w-full max-w-3xl px-5 sm:px-8;
  }

  .blog-post-tags {
    @apply flex flex-wrap gap-2;
  }

  .blog-post-tags span {
    @apply rounded-full bg-accent-soft px-3 py-1 text-xs font-semibold text-text;
  }

  .blog-post-header h1 {
    @apply mt-6 font-serif text-5xl leading-tight sm:text-6xl;
  }

  .blog-post-meta {
    @apply mt-5 text-sm text-text-soft;
  }

  .blog-post-excerpt {
    @apply mt-7 text-xl leading-8 text-text-soft;
  }

  .blog-post-body {
    @apply mt-12;
  }

  .blog-post-sources {
    @apply mt-14 border-t border-border pt-8;
  }

  .blog-post-sources h2 {
    @apply font-serif text-2xl font-bold text-text;
  }

  .blog-post-sources ul {
    @apply mt-4 grid gap-2;
  }

  .blog-post-sources a {
    @apply font-semibold text-accent-strong;
  }

  .blog-post-nav {
    @apply mt-14 grid gap-4 border-t border-border pt-8 sm:grid-cols-2;
  }

  .blog-post-nav-link {
    @apply grid gap-1 rounded-2xl border border-border bg-surface p-5 no-underline transition-colors hover:border-accent-strong;
  }

  .blog-post-nav-next {
    @apply text-right;
  }

  .blog-post-nav-link span {
    @apply text-xs font-bold uppercase tracking-[0.14em] text-accent-strong;
  }

  .blog-post-nav-link strong {
    @apply font-serif text-lg text-text;
  }
</style>
