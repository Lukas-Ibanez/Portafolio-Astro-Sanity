---
import interFont from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import plusJakartaFont from '@fontsource-variable/plus-jakarta-sans/files/plus-jakarta-sans-latin-wght-normal.woff2?url';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import FloatingIcosahedron from '../components/FloatingIcosahedron.astro';
import { buildSeo } from '../lib/seo';
import '../styles/global.css';

type Props = {
  title?: string;
  description?: string;
  path?: string;
  image?: string;
  type?: 'website' | 'article';
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
};

const seo = buildSeo({
  title: Astro.props.title || 'Lukas Ibáñez | Desarrollador Full-Stack',
  description:
    Astro.props.description ||
    'Desarrollador Full-Stack chileno enfocado en proyectos web completos: Linux, seguridad, frontend, backend, SEO y performance.',
  path: Astro.props.path || Astro.url.pathname,
  image: Astro.props.image,
  type: Astro.props.type || 'website',
});

const jsonLd = Astro.props.jsonLd;
---

<!doctype html>
<html lang="es-CL">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta id="theme-color-meta" name="theme-color" content="#F7F4EE" />
    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      (function () {
        var saved = localStorage.getItem('theme');
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        var theme = saved || (prefersDark ? 'dark' : 'light');
        document.documentElement.setAttribute('data-theme', theme);
        var meta = document.getElementById('theme-color-meta');
        if (meta) meta.setAttribute('content', theme === 'dark' ? '#1A1815' : '#F7F4EE');
      })();
    </script>
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    <link rel="canonical" href={seo.canonical} />
    <link rel="preload" href={interFont} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={plusJakartaFont} as="font" type="font/woff2" crossorigin />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    <meta property="og:locale" content="es_CL" />
    <meta property="og:type" content={seo.type} />
    <meta property="og:title" content={seo.title} />
    <meta property="og:description" content={seo.description} />
    <meta property="og:url" content={seo.canonical} />
    <meta property="og:image" content={seo.image} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seo.title} />
    <meta name="twitter:description" content={seo.description} />
    <meta name="twitter:image" content={seo.image} />

    {
      jsonLd && (
        <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
      )
    }
  </head>
  <body id="site-body" class="site-body">
    <a
      href="#contenido"
      class="skip-link"
    >
      Saltar al contenido
    </a>

    <Nav />
    <main id="contenido">
      <slot />
    </main>
    <Footer />

    <FloatingIcosahedron />

    <script>
      import '../scripts/animations';
    </script>
  </body>
</html>

<style>
  .site-body {
    @apply min-h-screen font-sans text-text antialiased selection:bg-accent-soft selection:text-text;
  }

  .skip-link {
    @apply sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-full focus:bg-surface focus:px-4 focus:py-2 focus:text-text focus:shadow-soft;
  }
</style>
