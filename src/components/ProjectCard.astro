---
import type { CollectionEntry } from 'astro:content';
import ArrowRight from './icons/ArrowRight.astro';
import ExternalLink from './icons/ExternalLink.astro';

type Props = {
  project: CollectionEntry<'projects'>;
  index?: number;
};

const { project, index = 0 } = Astro.props;
const data = project.data;
const slug = project.id;
const detailHref = `/proyectos/${slug}/`;
const projectNumber = String(index + 1).padStart(2, '0');
const showImage = Boolean(data.coverImage) && !data.confidential;
---

<article class="project-card group batch-reveal" data-project-card>
  <a class="project-card-media" href={detailHref} aria-label={`Ver caso de estudio: ${data.title}`}>
    {
      showImage ? (
        <img
          src={data.coverImage}
          alt={data.coverAlt || `Imagen del proyecto ${data.title}.`}
          width={1600}
          height={800}
          loading="lazy"
          decoding="async"
          class="project-card-image"
        />
      ) : (
        <div class="project-card-cover" aria-hidden="true">
          <span class="project-card-cover-client">{data.client}</span>
          <strong class="project-card-cover-title">{data.title}</strong>
          {data.confidential && <span class="project-card-nda">Proyecto bajo confidencialidad</span>}
        </div>
      )
    }
  </a>

  <div class="project-card-body">
    <div class="project-card-meta">
      <span>{projectNumber}</span>
      <span>{data.client} · {data.year}</span>
    </div>

    <h3 class="project-card-title">
      <a href={detailHref}>{data.title}</a>
    </h3>
    <p class="project-card-role">{data.role}</p>
    <p class="project-card-summary">{data.summary}</p>

    <div class="project-card-stack">
      {data.stack.slice(0, 5).map((item) => <span>{item}</span>)}
    </div>

    <div class="project-card-actions">
      <a href={detailHref} class="button-primary">Caso de estudio <ArrowRight /></a>
      {data.externalUrl && (
        <a href={data.externalUrl} class="button-secondary" rel="noreferrer noopener" target="_blank">
          Ver sitio <ExternalLink />
        </a>
      )}
      {data.repoUrl && (
        <a href={data.repoUrl} class="button-secondary" rel="noreferrer noopener" target="_blank">
          Código <ExternalLink />
        </a>
      )}
    </div>
  </div>
</article>

<style>
  .project-card {
    @apply flex h-full flex-col overflow-hidden border border-border bg-surface shadow-soft;
    border-radius: 1.05rem;
  }

  .project-card-media {
    @apply relative block aspect-[2/1] overflow-hidden border-b border-border no-underline;
  }

  .project-card-image {
    @apply h-full w-full object-cover transition duration-500 group-hover:scale-[1.04];
  }

  .project-card-cover {
    @apply flex h-full w-full flex-col justify-center gap-2 p-6;
    background:
      radial-gradient(circle at 80% 16%, var(--accent-spot), transparent 12rem),
      linear-gradient(135deg, var(--color-bg-alt), var(--color-surface));
  }

  .project-card-cover-client {
    @apply text-xs font-bold uppercase tracking-[0.2em] text-accent-strong;
  }

  .project-card-cover-title {
    @apply font-serif text-2xl font-bold leading-tight text-text sm:text-3xl;
  }

  .project-card-nda {
    @apply mt-2 inline-flex w-fit items-center gap-2 rounded-full border border-border bg-bg px-3 py-1 text-xs font-semibold text-text-soft;
  }

  .project-card-body {
    @apply flex flex-1 flex-col p-6 sm:p-7;
  }

  .project-card-meta {
    @apply flex items-center justify-between gap-4 text-xs font-bold uppercase tracking-[0.14em];
  }

  .project-card-meta span:first-child {
    @apply text-accent-strong;
  }

  .project-card-meta span:last-child {
    @apply text-text-soft;
  }

  .project-card-title {
    @apply mt-5 font-serif text-2xl font-bold leading-tight text-text sm:text-3xl;
  }

  .project-card-title a {
    @apply text-text no-underline transition-colors hover:text-accent-strong;
  }

  .project-card-role {
    @apply mt-2 text-sm font-semibold text-accent-strong;
  }

  .project-card-summary {
    @apply mt-4 text-base leading-7 text-text-soft;
  }

  .project-card-stack {
    @apply mt-6 flex flex-wrap gap-2;
  }

  .project-card-stack span {
    @apply border border-border bg-bg px-3 py-1.5 text-xs font-bold text-text-soft;
    border-radius: 999px;
  }

  .project-card-actions {
    @apply mt-auto flex flex-wrap gap-3 pt-8;
  }
</style>
