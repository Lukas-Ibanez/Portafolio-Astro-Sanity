---
interface Props {
  brand: string;
}

const { brand } = Astro.props;
---

<span class:list={['brand-logo', `brand-logo-${brand}`]} aria-hidden="true">
  {
    brand === 'astro' && (
      <svg viewBox="0 0 64 64" role="img">
        <path class="brand-fill" d="M32 6 52 58 38 49l-6 9-6-9-14 9L32 6Z" />
        <path class="brand-cut" d="M32 20 40 43H24l8-23Z" />
        <path class="brand-accent" d="M48 8l2 5 5 2-5 2-2 5-2-5-5-2 5-2 2-5Z" />
      </svg>
    )
  }

  {
    brand === 'react' && (
      <svg viewBox="0 0 64 64" role="img">
        <circle class="brand-fill" cx="32" cy="32" r="5.5" />
        <ellipse class="brand-stroke" cx="32" cy="32" rx="25" ry="9" />
        <ellipse class="brand-stroke" cx="32" cy="32" rx="25" ry="9" transform="rotate(60 32 32)" />
        <ellipse class="brand-stroke" cx="32" cy="32" rx="25" ry="9" transform="rotate(120 32 32)" />
      </svg>
    )
  }

  {
    brand === 'javascript' && (
      <svg viewBox="0 0 64 64" role="img">
        <rect class="brand-fill" x="10" y="10" width="44" height="44" rx="4" />
        <text x="32" y="43" text-anchor="middle">JS</text>
      </svg>
    )
  }

  {
    brand === 'typescript' && (
      <svg viewBox="0 0 64 64" role="img">
        <rect class="brand-fill" x="10" y="10" width="44" height="44" rx="4" />
        <text x="32" y="43" text-anchor="middle">TS</text>
      </svg>
    )
  }

  {
    brand === 'php' && (
      <svg viewBox="0 0 64 64" role="img">
        <ellipse class="brand-fill" cx="32" cy="32" rx="27" ry="17" />
        <text x="32" y="37" text-anchor="middle">PHP</text>
      </svg>
    )
  }

  {
    brand === 'python' && (
      <svg viewBox="0 0 64 64" role="img">
        <path class="brand-fill" d="M31 8c-10 0-15 4-15 11v8h17v4H14c-7 0-11 5-11 13 0 7 4 12 11 12h8v-9c0-7 5-12 13-12h14c6 0 11-5 11-12v-4c0-7-5-11-15-11H31Z" />
        <path class="brand-accent" d="M33 56c10 0 15-4 15-11v-8H31v-4h19c7 0 11-5 11-13 0-7-4-12-11-12h-8v9c0 7-5 12-13 12H15c-6 0-11 5-11 12v4c0 7 5 11 15 11h14Z" />
        <circle class="brand-cut" cx="24" cy="17" r="2.2" />
        <circle class="brand-cut" cx="40" cy="47" r="2.2" />
      </svg>
    )
  }

  {
    brand === 'java' && (
      <svg viewBox="0 0 64 64" role="img">
        <path class="brand-accent" d="M34 8c8 8-12 10-2 21 4 4 1 8-5 12 3-5 3-8-1-12-8-10 12-12 8-21Z" />
        <path class="brand-fill" d="M19 42c8 4 22 4 30-1-2 7-27 9-34 2 1-.8 2-1 4-1Z" />
        <path class="brand-fill" d="M17 49c11 4 25 4 35-2-1 8-30 10-40 2 1-.8 3-1 5 0Z" />
        <path class="brand-fill" d="M22 35c8 3 18 3 25-1-2 5-19 7-27 2 .4-.5 1-.8 2-1Z" />
      </svg>
    )
  }

  {
    brand === 'css' && (
      <svg viewBox="0 0 64 64" role="img">
        <path class="brand-fill" d="M12 8h40l-4 45-16 5-16-5L12 8Z" />
        <path class="brand-cut" d="M22 19h22l-.7 7H29l.4 5h13.4l-1.2 14L32 48l-9.6-3-.7-8h7l.3 3 3 1 3-1 .4-4H21.2L19.8 19H22Z" />
      </svg>
    )
  }

  {
    brand === 'node' && (
      <svg viewBox="0 0 64 64" role="img">
        <path class="brand-fill" d="M32 6 55 19v26L32 58 9 45V19L32 6Z" />
        <text x="32" y="38" text-anchor="middle">JS</text>
      </svg>
    )
  }

  {
    brand === 'tailwind' && (
      <svg viewBox="0 0 64 64" role="img">
        <path class="brand-fill" d="M17 28c4-11 11-15 21-12 6 2 9 6 12 11-4-3-8-4-12-2-4 2-6 6-11 7-4 1-8-1-10-4Z" />
        <path class="brand-fill" d="M10 43c4-11 11-15 21-12 6 2 9 6 12 11-4-3-8-4-12-2-4 2-6 6-11 7-4 1-8-1-10-4Z" />
      </svg>
    )
  }

  {
    brand === 'gsap' && (
      <svg viewBox="0 0 64 64" role="img">
        <rect class="brand-fill" x="8" y="14" width="48" height="36" rx="18" />
        <text x="32" y="38" text-anchor="middle">GS</text>
      </svg>
    )
  }

  {
    brand === 'wordpress' && (
      <svg viewBox="0 0 64 64" role="img">
        <circle class="brand-fill" cx="32" cy="32" r="25" />
        <circle class="brand-cut" cx="32" cy="32" r="20" />
        <text x="32" y="42" text-anchor="middle">W</text>
      </svg>
    )
  }

  {
    brand === 'mysql' && (
      <svg viewBox="0 0 64 64" role="img">
        <path class="brand-fill" d="M14 37c5-12 17-20 32-20 3 0 6 .3 8 1-8 4-12 10-15 19-2 6-8 10-16 10-8 0-14-3-19-8 4 1 8 1 10-2Z" />
        <path class="brand-accent" d="M45 18c5 1 8 4 10 8-5-2-10-1-15 1 1-3 3-6 5-9Z" />
      </svg>
    )
  }

  {
    brand === 'postgresql' && (
      <svg viewBox="0 0 64 64" role="img">
        <path class="brand-fill" d="M20 46c-6-4-9-11-8-20 1-12 10-20 22-20 13 0 21 8 21 20 0 11-6 18-16 21l-4 8-5-7c-4 1-7 0-10-2Z" />
        <circle class="brand-cut" cx="26" cy="27" r="3" />
        <circle class="brand-cut" cx="42" cy="27" r="3" />
        <path class="brand-cut" d="M31 37c4 3 8 3 12 0" />
      </svg>
    )
  }

  {
    brand === 'linux' && (
      <svg viewBox="0 0 64 64" role="img">
        <path class="brand-fill" d="M32 7c9 0 14 8 13 19 5 6 8 13 8 21 0 6-5 10-12 7-3 4-13 4-16 0-7 3-12-1-12-7 0-8 3-15 8-21-1-11 4-19 11-19Z" />
        <circle class="brand-cut" cx="27" cy="22" r="2.2" />
        <circle class="brand-cut" cx="37" cy="22" r="2.2" />
        <path class="brand-accent" d="M27 34h10l-5 6-5-6Z" />
      </svg>
    )
  }

  {
    brand === 'nginx' && (
      <svg viewBox="0 0 64 64" role="img">
        <path class="brand-fill" d="M32 6 55 19v26L32 58 9 45V19L32 6Z" />
        <text x="32" y="40" text-anchor="middle">N</text>
      </svg>
    )
  }
</span>

<style>
  .brand-logo {
    @apply inline-flex h-10 w-10 items-center justify-center;
  }

  .brand-logo svg {
    @apply h-full w-full;
  }

  .brand-fill,
  .brand-accent,
  .brand-cut,
  .brand-stroke {
    vector-effect: non-scaling-stroke;
  }

  .brand-stroke {
    fill: none;
    stroke: currentColor;
    stroke-width: 3;
  }

  .brand-cut {
    fill: var(--color-bg);
  }

  .brand-logo text {
    font-family: var(--font-display);
    font-size: 19px;
    font-weight: 800;
    fill: var(--color-bg);
    letter-spacing: 0;
  }

  .brand-logo-astro .brand-fill { fill: #2b2a27; }
  .brand-logo-astro .brand-accent { fill: #ff5d01; }
  .brand-logo-react { color: #149eca; }
  .brand-logo-react .brand-fill { fill: #149eca; }
  .brand-logo-javascript .brand-fill { fill: #f7df1e; }
  .brand-logo-javascript text { fill: #2b2a27; }
  .brand-logo-typescript .brand-fill { fill: #3178c6; }
  .brand-logo-php .brand-fill { fill: #777bb4; }
  .brand-logo-python .brand-fill { fill: #3776ab; }
  .brand-logo-python .brand-accent { fill: #ffd43b; }
  .brand-logo-java .brand-fill { fill: #5382a1; }
  .brand-logo-java .brand-accent { fill: #e76f00; }
  .brand-logo-css .brand-fill { fill: #1572b6; }
  .brand-logo-css .brand-cut { fill: #fbfaf7; }
  .brand-logo-node .brand-fill { fill: #68a063; }
  .brand-logo-tailwind .brand-fill { fill: #38bdf8; }
  .brand-logo-gsap .brand-fill { fill: #88ce02; }
  .brand-logo-gsap text { fill: #1f2a16; }
  .brand-logo-wordpress .brand-fill { fill: #21759b; }
  .brand-logo-wordpress text { fill: #21759b; font-family: Georgia, serif; font-size: 28px; }
  .brand-logo-mysql .brand-fill { fill: #00758f; }
  .brand-logo-mysql .brand-accent { fill: #f29111; }
  .brand-logo-postgresql .brand-fill { fill: #336791; }
  .brand-logo-postgresql .brand-cut { fill: #fbfaf7; stroke: #fbfaf7; stroke-width: 3; }
  .brand-logo-linux .brand-fill { fill: #2b2a27; }
  .brand-logo-linux .brand-accent { fill: #f6c343; }
  .brand-logo-nginx .brand-fill { fill: #009639; }
</style>
