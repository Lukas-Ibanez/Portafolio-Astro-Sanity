<canvas id="ico-canvas" aria-hidden="true"></canvas>

<style>
  #ico-canvas {
    position: fixed;
    inset: 0;
    z-index: -1;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    #ico-canvas { display: none; }
  }
</style>

<script>
  import * as THREE from 'three';

  const canvas = document.getElementById('ico-canvas') as HTMLCanvasElement;
  if (!canvas) throw new Error('ico-canvas not found');

  // Reduce intensity on small viewports (lighter GPU load, less motion).
  const smallViewport = () => window.matchMedia('(max-width: 768px)').matches;
  let isSmall = smallViewport();

  // ── Renderer ───────────────────────────────────────────────────────────────
  const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, isSmall ? 1.5 : 2));
  renderer.setSize(window.innerWidth, window.innerHeight);
  renderer.setClearColor(0x000000, 0);

  // ── Scene & Camera ─────────────────────────────────────────────────────────
  const scene = new THREE.Scene();
  const camera = new THREE.PerspectiveCamera(52, window.innerWidth / window.innerHeight, 0.1, 50);
  camera.position.z = 6;

  // ── Theme ──────────────────────────────────────────────────────────────────
  const isDark = () => document.documentElement.dataset.theme === 'dark';

  // ── Geometry: geodesic wireframe sphere ────────────────────────────────────
  const icoGeo = new THREE.IcosahedronGeometry(0.75, 2);
  const edgesGeo = new THREE.EdgesGeometry(icoGeo);

  const wireMat = new THREE.LineBasicMaterial({ transparent: true });
  const wireframe = new THREE.LineSegments(edgesGeo, wireMat);
  scene.add(wireframe);

  const fillMat = new THREE.MeshBasicMaterial({
    transparent: true,
    side: THREE.BackSide,
  });
  const fillMesh = new THREE.Mesh(new THREE.IcosahedronGeometry(0.73, 2), fillMat);
  scene.add(fillMesh);

  function syncTheme() {
    const dark = isDark();
    wireMat.color.setHex(dark ? 0xd4856a : 0xcc785c);
    wireMat.opacity = dark ? 0.50 : 0.58;
    fillMat.color.setHex(dark ? 0xb04830 : 0xcc785c);
    fillMat.opacity = dark ? 0.08 : 0.06;
  }
  syncTheme();

  // ── Dynamic X: stays in viewport at any aspect ratio ──────────────────────
  function sideXPct(side: 'L' | 'R'): number {
    const vw = window.innerWidth;
    const vh = window.innerHeight;
    // Sphere radius in px ≈ 0.095 * vh (depends on camera fov and scale).
    // Keep sphere center at least (radius + 30px) from the viewport edge
    // so it never clips regardless of viewport aspect ratio.
    const pxFromEdge = Math.max(0.10 * vh + 30, 90); // min 90px
    const pct = Math.min(0.16, pxFromEdge / vw);      // max 16% from edge
    return side === 'L' ? pct : 1 - pct;
  }

  // ── Viewport % → world position ────────────────────────────────────────────
  function vpToWorld(xPct: number, yPct: number) {
    const fovR = (camera.fov * Math.PI) / 180;
    const h = 2 * Math.tan(fovR / 2) * camera.position.z;
    return { x: (xPct - 0.5) * h * camera.aspect, y: -(yPct - 0.5) * h };
  }

  // ── Section anchors ─────────────────────────────────────────────────────────
  // Instead of guessing scroll-progress percentages, the sphere is anchored to
  // the REAL position of each Home section in the document. The anchor for a
  // section is the scroll position at which the section's vertical center lines
  // up with the viewport center. This stays consistent across viewport sizes and
  // content changes. `side` places the sphere where there is no opaque panel.
  interface SectionCfg { id: string; side: 'L' | 'R'; yPct: number; s: number }
  const SECTION_CFG: SectionCfg[] = [
    { id: 'hero',              side: 'R', yPct: 0.46, s: 0.66 },
    { id: 'stats',             side: 'R', yPct: 0.48, s: 0.62 },
    { id: 'about',             side: 'L', yPct: 0.50, s: 0.60 },
    { id: 'skills',            side: 'L', yPct: 0.46, s: 0.58 },
    { id: 'featured-projects', side: 'R', yPct: 0.48, s: 0.62 },
    { id: 'blog-teaser',       side: 'L', yPct: 0.46, s: 0.60 },
    { id: 'contact',           side: 'R', yPct: 0.46, s: 0.62 },
  ];

  interface Anchor { y: number; side: 'L' | 'R'; yPct: number; s: number }
  let anchors: Anchor[] = [];

  function maxScroll() {
    return Math.max(1, document.documentElement.scrollHeight - window.innerHeight);
  }

  function computeAnchors() {
    const ms = maxScroll();
    const present = SECTION_CFG
      .map((cfg) => ({ cfg, el: document.getElementById(cfg.id) }))
      .filter((entry): entry is { cfg: SectionCfg; el: HTMLElement } => Boolean(entry.el));

    let next: Anchor[];
    if (present.length >= 2) {
      next = present.map(({ cfg, el }) => {
        const rect = el.getBoundingClientRect();
        const center = rect.top + window.scrollY + rect.height / 2;
        const y = Math.max(0, Math.min(ms, center - window.innerHeight / 2));
        return { y, side: cfg.side, yPct: cfg.yPct, s: cfg.s };
      });
    } else {
      // Fallback for internal pages that don't have the Home sections.
      next = [
        { y: 0, side: 'R', yPct: 0.42, s: 0.6 },
        { y: ms, side: 'L', yPct: 0.5, s: 0.58 },
      ];
    }

    // Guarantee strictly increasing anchor positions (avoids divide-by-zero).
    for (let i = 1; i < next.length; i++) {
      if (next[i].y <= next[i - 1].y) next[i].y = next[i - 1].y + 1;
    }
    anchors = next;
  }

  function easeInOut(t: number) {
    const c = t < 0 ? 0 : t > 1 ? 1 : t;
    return c < 0.5 ? 2 * c * c : -1 + (4 - 2 * c) * c;
  }

  function sampleAt(a: Anchor, b: Anchor, e: number) {
    const xa = sideXPct(a.side);
    const xb = sideXPct(b.side);
    const xPct = xa + (xb - xa) * e;
    const yPct = a.yPct + (b.yPct - a.yPct) * e;
    const s = a.s + (b.s - a.s) * e;
    const w = vpToWorld(xPct, yPct);
    return { x: w.x, y: w.y, s };
  }

  function targetForScroll(scrollY: number) {
    const first = anchors[0];
    const last = anchors[anchors.length - 1];
    if (scrollY <= first.y) return sampleAt(first, first, 0);
    if (scrollY >= last.y) return sampleAt(last, last, 0);
    for (let i = 0; i < anchors.length - 1; i++) {
      const a = anchors[i];
      const b = anchors[i + 1];
      if (scrollY >= a.y && scrollY <= b.y) {
        return sampleAt(a, b, easeInOut((scrollY - a.y) / (b.y - a.y)));
      }
    }
    return sampleAt(last, last, 0);
  }

  computeAnchors();
  const initState = targetForScroll(window.scrollY);
  const target = { x: initState.x, y: initState.y, s: initState.s };
  const cur = { x: initState.x, y: initState.y, s: initState.s };

  // One-time entrance: when loading at the top, start the sphere offscreen-left
  // and let the render loop glide it to its hero anchor (left → right reveal).
  if ((window.scrollY || 0) < 8) {
    const introH = 2 * Math.tan((camera.fov * Math.PI) / 180 / 2) * camera.position.z;
    cur.x -= introH * camera.aspect * 0.95;
  }

  wireframe.position.set(cur.x, cur.y, 0);
  fillMesh.position.set(cur.x, cur.y, 0);
  wireframe.scale.setScalar(cur.s);
  fillMesh.scale.setScalar(cur.s);

  // ── Render loop ────────────────────────────────────────────────────────────
  const startTime = performance.now();

  function tick() {
    requestAnimationFrame(tick);
    const t = (performance.now() - startTime) / 1000;

    // Sample the real scroll position every frame and ease toward it. A single
    // smoothing pass (no ScrollTrigger scrub) keeps the sphere in sync with the
    // page instead of lagging behind during fast scroll or momentum.
    const desired = targetForScroll(window.scrollY || window.pageYOffset || 0);
    target.x = desired.x;
    target.y = desired.y;
    target.s = desired.s;

    const L = 0.11;
    cur.x += (target.x - cur.x) * L;
    cur.y += (target.y - cur.y) * L;
    cur.s += (target.s - cur.s) * L;

    // Damp motion on small screens to avoid jank.
    const intensity = isSmall ? 0.5 : 1;
    const floatY = Math.sin(t * 0.68) * 0.042 * intensity;

    wireframe.position.set(cur.x, cur.y + floatY, 0);
    fillMesh.position.set(cur.x, cur.y + floatY, 0);
    wireframe.scale.setScalar(cur.s);
    fillMesh.scale.setScalar(cur.s);

    wireframe.rotation.y = t * 0.30 * intensity;
    wireframe.rotation.x = (t * 0.10 + Math.sin(t * 0.17) * 0.18) * intensity;
    wireframe.rotation.z = Math.sin(t * 0.09) * 0.10 * intensity;
    fillMesh.rotation.copy(wireframe.rotation);

    renderer.render(scene, camera);
  }
  tick();

  // ── Resize ─────────────────────────────────────────────────────────────────
  function handleResize() {
    isSmall = smallViewport();
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, isSmall ? 1.5 : 2));
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
    computeAnchors();
    // Snap to the correct world position for the new viewport/layout.
    const snap = targetForScroll(window.scrollY);
    cur.x = target.x = snap.x;
    cur.y = target.y = snap.y;
    cur.s = target.s = snap.s;
  }

  window.addEventListener('resize', handleResize);
  // Section offsets shift as fonts/images settle — recompute when they do.
  window.addEventListener('load', computeAnchors);

  if ('ResizeObserver' in window) {
    let pending = 0;
    const observer = new ResizeObserver(() => {
      cancelAnimationFrame(pending);
      pending = requestAnimationFrame(computeAnchors);
    });
    observer.observe(document.body);
  }

  // ── Theme change ───────────────────────────────────────────────────────────
  new MutationObserver(syncTheme).observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['data-theme'],
  });
</script>
