---
import type { CollectionEntry } from 'astro:content';
import ProjectCard from './ProjectCard.astro';
import ArrowRight from './icons/ArrowRight.astro';
import linuxImage from '../assets/project-linux.png';
import adminImage from '../assets/project-admin.png';
import seoImage from '../assets/project-seo.png';
import apiImage from '../assets/project-api.png';

type Props = {
  projects: CollectionEntry<'projects'>[];
  featuredOnly?: boolean;
};

const imageMap = {
  linux: linuxImage,
  admin: adminImage,
  seo: seoImage,
  api: apiImage,
};

const { projects, featuredOnly = false } = Astro.props;
const sectionId = featuredOnly ? 'featured-projects' : 'projects';
const visibleProjects = projects
  .filter((project) => (featuredOnly ? project.data.featured : true))
  .sort((a, b) => a.data.order - b.data.order);
---

<section id={sectionId} class="projects-section">
  <div class="projects-container">
    <div id={`${sectionId}-intro`} class="projects-intro reveal">
      <div>
        <p class="eyebrow">Proyectos</p>
        <h2 class="projects-title section-title">{featuredOnly ? 'Trabajo destacado' : 'Proyectos seleccionados'}</h2>
      </div>
      {
        featuredOnly && (
          <a href="/proyectos/" class="button-secondary">
            Ver todos <ArrowRight />
          </a>
        )
      }
    </div>
    <div id={`${sectionId}-grid`} class="projects-grid">
      {
        visibleProjects.map((project) => (
          <ProjectCard
            title={project.data.title}
            excerpt={project.data.excerpt}
            stack={project.data.stack}
            role={project.data.role}
            liveUrl={project.data.liveUrl}
            repoUrl={project.data.repoUrl}
            image={imageMap[project.data.image as keyof typeof imageMap] || linuxImage}
          />
        ))
      }
    </div>
  </div>
</section>

<style>
  .projects-section {
    @apply bg-bg py-24;
  }

  .projects-container {
    @apply mx-auto w-full max-w-site px-5 sm:px-8;
  }

  .projects-intro {
    @apply flex flex-col gap-6 sm:flex-row sm:items-end sm:justify-between;
  }

  .projects-title {
    @apply mt-4;
  }

  .projects-grid {
    @apply mt-12 grid gap-6 md:grid-cols-2;
  }
</style>
