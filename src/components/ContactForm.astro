---
import { web3formsKey } from '../data/site';
---

<form id="contact-form" class="contact-form" data-contact-form data-access-key={web3formsKey} novalidate>
  <div class="contact-form-row">
    <label class="contact-field">
      <span>Nombre</span>
      <input type="text" name="name" autocomplete="name" required minlength="2" placeholder="Tu nombre" />
    </label>
    <label class="contact-field">
      <span>Email</span>
      <input type="email" name="email" autocomplete="email" required placeholder="tu@correo.com" />
    </label>
  </div>

  <label class="contact-field">
    <span>Mensaje</span>
    <textarea name="message" rows="5" required minlength="10" placeholder="Cuéntame del proyecto o la oportunidad."></textarea>
  </label>

  {/* Honeypot — hidden from humans, bots tend to fill it. */}
  <div class="contact-hp" aria-hidden="true">
    <label>No llenar este campo
      <input type="text" name="botcheck" tabindex="-1" autocomplete="off" />
    </label>
  </div>

  <div class="contact-form-footer">
    <button type="submit" class="button-primary" data-contact-submit>Enviar mensaje</button>
    <p class="contact-form-status" data-contact-status role="status" aria-live="polite"></p>
  </div>
</form>

<style>
  .contact-form {
    @apply mt-8 grid gap-5 rounded-2xl border border-border bg-surface p-6 shadow-soft sm:p-8;
  }

  .contact-form-row {
    @apply grid gap-5 sm:grid-cols-2;
  }

  .contact-field {
    @apply grid gap-2;
  }

  .contact-field > span {
    @apply text-sm font-bold text-text;
  }

  .contact-field input,
  .contact-field textarea {
    @apply w-full rounded-xl border border-border bg-bg px-4 py-3 text-base text-text;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .contact-field input::placeholder,
  .contact-field textarea::placeholder {
    color: var(--color-text-soft);
  }

  .contact-field input:focus-visible,
  .contact-field textarea:focus-visible {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px var(--accent-scan);
  }

  .contact-field input[aria-invalid='true'],
  .contact-field textarea[aria-invalid='true'] {
    border-color: #c0492f;
  }

  /* Honeypot: visually + accessibly hidden, still submittable by bots */
  .contact-hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .contact-form-footer {
    @apply flex flex-wrap items-center gap-4;
  }

  .contact-form-status {
    @apply text-sm font-semibold;
  }

  .contact-form-status[data-state='error'] {
    color: #c0492f;
  }

  .contact-form-status[data-state='success'] {
    color: var(--color-sage);
  }

  .contact-form[data-loading='true'] [data-contact-submit] {
    opacity: 0.7;
    pointer-events: none;
  }
</style>

<script>
  const form = document.querySelector<HTMLFormElement>('[data-contact-form]');

  if (form) {
    const status = form.querySelector<HTMLElement>('[data-contact-status]');
    const accessKey = form.dataset.accessKey || '';
    const fields = ['name', 'email', 'message'] as const;

    const setStatus = (message: string, state: 'error' | 'success' | '' = '') => {
      if (!status) return;
      status.textContent = message;
      if (state) status.dataset.state = state;
      else status.removeAttribute('data-state');
    };

    const isEmail = (value: string) => /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value);

    const validate = () => {
      let firstInvalid: HTMLElement | null = null;
      for (const name of fields) {
        const field = form.elements.namedItem(name) as HTMLInputElement | HTMLTextAreaElement | null;
        if (!field) continue;
        const value = field.value.trim();
        let invalid = value.length === 0;
        if (name === 'email' && !invalid) invalid = !isEmail(value);
        if (name === 'message' && !invalid) invalid = value.length < 10;
        field.setAttribute('aria-invalid', invalid ? 'true' : 'false');
        if (invalid && !firstInvalid) firstInvalid = field;
      }
      return firstInvalid;
    };

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      // Honeypot: if filled, silently pretend success.
      const honey = form.elements.namedItem('botcheck') as HTMLInputElement | null;
      if (honey && honey.value) {
        setStatus('¡Gracias! Mensaje enviado.', 'success');
        form.reset();
        return;
      }

      const firstInvalid = validate();
      if (firstInvalid) {
        firstInvalid.focus();
        setStatus('Revisa los campos marcados antes de enviar.', 'error');
        return;
      }

      if (!accessKey) {
        setStatus('El formulario aún no está configurado. Escríbeme directo por correo.', 'error');
        return;
      }

      const payload = {
        access_key: accessKey,
        name: (form.elements.namedItem('name') as HTMLInputElement).value.trim(),
        email: (form.elements.namedItem('email') as HTMLInputElement).value.trim(),
        message: (form.elements.namedItem('message') as HTMLTextAreaElement).value.trim(),
        subject: 'Nuevo mensaje desde el portafolio',
        from_name: 'Portafolio Lukas Ibáñez',
      };

      form.dataset.loading = 'true';
      setStatus('Enviando…');

      try {
        const response = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify(payload),
        });
        const result = await response.json();

        if (response.ok && result.success) {
          setStatus('¡Gracias! Tu mensaje fue enviado. Te responderé pronto.', 'success');
          form.reset();
        } else {
          setStatus('No pude enviar el mensaje. Inténtalo de nuevo o escríbeme por correo.', 'error');
        }
      } catch {
        setStatus('Hubo un problema de red. Inténtalo de nuevo o escríbeme por correo.', 'error');
      } finally {
        form.dataset.loading = 'false';
      }
    });

    fields.forEach((name) => {
      const field = form.elements.namedItem(name) as HTMLElement | null;
      field?.addEventListener('input', () => field.setAttribute('aria-invalid', 'false'));
    });
  }
</script>
