---
import type { GithubRepo } from '../lib/github';
import ExternalLink from './icons/ExternalLink.astro';

type Props = {
  repos: GithubRepo[];
};

const { repos } = Astro.props;
---

{
  repos.length > 0 && (
    <section class="bg-bg-alt py-20">
      <div class="container-site">
        <div class="reveal max-w-3xl">
          <p class="eyebrow">GitHub</p>
          <h2 class="section-title mt-4">Repos actualizados recientemente</h2>
          <p class="section-copy mt-5">
            Estos datos se consultan durante el build y quedan horneados en el HTML. El navegador no llama a GitHub.
          </p>
        </div>
        <div class="mt-10 grid gap-4 md:grid-cols-2">
          {repos.map((repo) => (
            <article class="batch-reveal rounded-2xl border border-border bg-surface p-6">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <h3 class="font-serif text-2xl">{repo.name}</h3>
                  <p class="mt-3 text-sm leading-6 text-text-soft">{repo.description || 'Repositorio sin descripción pública.'}</p>
                </div>
                <a href={repo.url} class="rounded-full border border-border p-3 text-text-soft transition hover:text-accent-strong" aria-label={`Abrir ${repo.name}`}>
                  <ExternalLink />
                </a>
              </div>
              <div class="mt-5 flex flex-wrap gap-2 text-xs text-text-soft">
                {repo.language && <span class="rounded-full bg-bg px-3 py-1">{repo.language}</span>}
                <span class="rounded-full bg-bg px-3 py-1">{repo.stars} estrellas</span>
                <span class="rounded-full bg-bg px-3 py-1">Último push: {new Date(repo.pushedAt).toLocaleDateString('es-CL')}</span>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}
