---
import type { GithubRepo } from '../lib/github';
import ExternalLink from './icons/ExternalLink.astro';

type Props = {
  repos: GithubRepo[];
};

const { repos } = Astro.props;
---

{
  repos.length > 0 && (
    <section id="github-repos" class="github-repos-section">
      <div class="github-repos-container">
        <div id="github-repos-intro" class="github-repos-intro reveal">
          <p class="eyebrow">GitHub</p>
          <h2 class="github-repos-title section-title">Repos actualizados recientemente</h2>
          <p class="github-repos-copy section-copy">
            Estos datos se consultan durante el build y quedan horneados en el HTML. El navegador no llama a GitHub.
          </p>
        </div>
        <div id="github-repos-grid" class="github-repos-grid">
          {repos.map((repo) => (
            <article class="github-repo-card batch-reveal">
              <div class="github-repo-header">
                <div>
                  <h3>{repo.name}</h3>
                  <p>{repo.description || 'Repositorio sin descripción pública.'}</p>
                </div>
                <a href={repo.url} class="github-repo-link" aria-label={`Abrir ${repo.name}`}>
                  <ExternalLink />
                </a>
              </div>
              <div class="github-repo-meta">
                {repo.language && <span>{repo.language}</span>}
                <span>{repo.stars} estrellas</span>
                <span>Último push: {new Date(repo.pushedAt).toLocaleDateString('es-CL')}</span>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  )
}

<style>
  .github-repos-section {
    @apply bg-bg-alt py-20;
  }

  .github-repos-container {
    @apply mx-auto w-full max-w-site px-5 sm:px-8;
  }

  .github-repos-intro {
    @apply max-w-3xl;
  }

  .github-repos-title {
    @apply mt-4;
  }

  .github-repos-copy {
    @apply mt-5;
  }

  .github-repos-grid {
    @apply mt-10 grid gap-4 md:grid-cols-2;
  }

  .github-repo-card {
    @apply rounded-2xl border border-border bg-surface p-6;
  }

  .github-repo-header {
    @apply flex items-start justify-between gap-4;
  }

  .github-repo-header h3 {
    @apply font-serif text-2xl;
  }

  .github-repo-header p {
    @apply mt-3 text-sm leading-6 text-text-soft;
  }

  .github-repo-link {
    @apply rounded-full border border-border p-3 text-text-soft transition hover:text-accent-strong;
  }

  .github-repo-meta {
    @apply mt-5 flex flex-wrap gap-2 text-xs text-text-soft;
  }

  .github-repo-meta span {
    @apply rounded-full bg-bg px-3 py-1;
  }
</style>
