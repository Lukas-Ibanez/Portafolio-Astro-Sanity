---
const groups = [
  ['Desarrollo Web', ['Astro', 'React', 'Node.js', 'APIs REST', 'HTML semántico']],
  ['Lenguajes', ['TypeScript', 'JavaScript', 'PHP', 'SQL', 'Bash']],
  ['Frontend', ['Tailwind CSS', 'Accesibilidad', 'SEO técnico', 'Performance', 'GSAP']],
  ['Bases de datos', ['PostgreSQL', 'MySQL', 'SQLite', 'modelado relacional']],
  ['DevOps', ['Linux', 'Nginx', 'SSL', 'GitHub Actions', 'variables de entorno']],
];
---

<section class="bg-bg-alt py-24">
  <div class="container-site">
    <div class="reveal max-w-3xl">
      <p class="eyebrow">Skills</p>
      <h2 class="section-title mt-4">Herramientas para construir, publicar y mantener.</h2>
    </div>
    <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {
        groups.map(([title, skills]) => (
          <section class="batch-reveal rounded-2xl border border-border bg-surface p-6">
            <h3 class="font-serif text-2xl">{title}</h3>
            <div class="mt-5 flex flex-wrap gap-2">
              {(skills as string[]).map((skill) => (
                <span class="rounded-full border border-border bg-bg px-3 py-1.5 text-sm text-text-soft">{skill}</span>
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </div>
</section>
