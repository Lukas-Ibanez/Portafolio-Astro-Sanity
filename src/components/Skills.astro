---
const groups = [
  ['Desarrollo Web', ['Astro', 'React', 'Node.js', 'APIs REST', 'HTML semántico']],
  ['Lenguajes', ['TypeScript', 'JavaScript', 'PHP', 'SQL', 'Bash']],
  ['Frontend', ['Tailwind CSS', 'Accesibilidad', 'SEO técnico', 'Performance', 'GSAP']],
  ['Bases de datos', ['PostgreSQL', 'MySQL', 'SQLite', 'modelado relacional']],
  ['DevOps', ['Linux', 'Nginx', 'SSL', 'GitHub Actions', 'variables de entorno']],
];
---

<section id="skills" class="skills-section">
  <div class="skills-container">
    <div id="skills-intro" class="skills-intro reveal">
      <p class="eyebrow">Skills</p>
      <h2 class="skills-title section-title">Herramientas para construir, publicar y mantener.</h2>
    </div>
    <div id="skills-grid" class="skills-grid">
      {
        groups.map(([title, skills]) => (
          <section class="skill-group batch-reveal">
            <h3>{title}</h3>
            <div class="skill-list">
              {(skills as string[]).map((skill) => (
                <span>{skill}</span>
              ))}
            </div>
          </section>
        ))
      }
    </div>
  </div>
</section>

<style>
  .skills-section {
    @apply bg-bg-alt py-24;
  }

  .skills-container {
    @apply mx-auto w-full max-w-site px-5 sm:px-8;
  }

  .skills-intro {
    @apply max-w-3xl;
  }

  .skills-title {
    @apply mt-4;
  }

  .skills-grid {
    @apply mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-3;
  }

  .skill-group {
    @apply rounded-2xl border border-border bg-surface p-6;
  }

  .skill-group h3 {
    @apply font-serif text-2xl;
  }

  .skill-list {
    @apply mt-5 flex flex-wrap gap-2;
  }

  .skill-list span {
    @apply rounded-full border border-border bg-bg px-3 py-1.5 text-sm text-text-soft;
  }
</style>
