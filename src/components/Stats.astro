---
const metrics = [
  {
    value: '3',
    suffix: '+',
    label: 'años construyendo proyectos web',
    detail: 'desarrollo, mantención y despliegues reales.',
  },
  {
    value: 'Full-stack',
    suffix: '',
    label: 'ciclo técnico completo',
    detail: 'frontend, backend, datos y operación conectados.',
  },
  {
    value: 'Linux',
    suffix: '',
    label: 'base de producción',
    detail: 'servidores, SSL, permisos y deploy con criterio.',
  },
];

const workflow = ['Código', 'Backend', 'Servidor', 'Seguridad', 'SEO'];
---

<section id="stats" class="stats-section" data-stats-section>
  <div class="stats-layout">
    <div id="stats-intro" class="stats-intro" data-stats-intro>
      <p class="eyebrow">Base operativa</p>
      <h2>Un perfil full-stack pensado para equipos que necesitan avanzar sin perder control técnico.</h2>
      <p>
        La propuesta no es solo escribir código: es entender cómo cada decisión llega al servidor, al rendimiento y al usuario final.
      </p>
    </div>

    <div id="stats-system" class="stats-system" data-stats-system>
      <div class="stats-scan" data-stats-scan></div>

      <svg class="stats-lines" viewBox="0 0 760 360" aria-hidden="true">
        <path data-stats-path d="M72 178 C180 82 294 86 380 178 C468 270 586 270 688 170" />
        <path data-stats-path d="M92 264 C210 216 302 232 386 270 C484 314 594 276 678 224" />
        <circle data-stats-ring cx="380" cy="178" r="88" />
        <circle data-stats-ring cx="380" cy="178" r="148" />
      </svg>

      <div class="stats-metrics">
        {
          metrics.map((metric, index) => (
            <article class="stat-card" data-stat-card>
              <p class="stat-value">
                {
                  index === 0 ? (
                    <>
                      {/* SSR/no-JS fallback shows the real value (3), never 0. JS counts 0→3 in view. */}
                      <span data-stat-number data-stat-target={metric.value}>{metric.value}</span>
                      <span>{metric.suffix}</span>
                    </>
                  ) : (
                    <>
                      <span>{metric.value}</span>
                      {metric.suffix && <span>{metric.suffix}</span>}
                    </>
                  )
                }
              </p>
              <h3>{metric.label}</h3>
              <p>{metric.detail}</p>
            </article>
          ))
        }
      </div>

      <div class="stats-workflow" aria-label="Flujo técnico principal">
        {
          workflow.map((item) => (
            <div class="workflow-step" data-workflow-step>
              <span>{item}</span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .stats-section {
    @apply relative isolate overflow-hidden border-y border-border bg-bg py-20;
    background:
      linear-gradient(90deg, var(--grid-color-h) 1px, transparent 1px),
      linear-gradient(180deg, var(--grid-color-v) 1px, transparent 1px);
    background-size: 4rem 4rem;
  }

  .stats-layout {
    @apply mx-auto grid w-full max-w-site gap-10 px-5 sm:px-8 lg:grid-cols-[1.22fr_0.78fr] lg:items-center;
  }

  .stats-intro {
    @apply max-w-xl;
  }

  @media (min-width: 1024px) {
    .stats-intro {
      grid-column: 2;
      justify-self: end;
    }

    .stats-system {
      grid-column: 1;
      grid-row: 1;
    }
  }

  .stats-intro h2 {
    @apply mt-4 font-serif text-4xl font-bold leading-tight text-text sm:text-5xl;
  }

  .stats-intro p:not(.eyebrow) {
    @apply mt-6 text-base leading-8 text-text-soft sm:text-lg;
  }

  .stats-system {
    @apply relative min-h-[32rem] overflow-hidden border border-border p-4 shadow-line sm:p-6;
    background: var(--panel-bg);
    border-radius: 1.1rem;
    isolation: isolate;
  }

  .stats-system::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -2;
    background:
      radial-gradient(circle at 34% 44%, var(--accent-spot), transparent 0.55rem),
      linear-gradient(90deg, var(--panel-grid-h) 1px, transparent 1px),
      linear-gradient(180deg, var(--panel-grid-v) 1px, transparent 1px);
    background-size: 1rem 1rem, 3rem 3rem, 3rem 3rem;
  }

  .stats-scan {
    @apply pointer-events-none absolute inset-y-0 left-0 z-0 w-24 opacity-40;
    background: linear-gradient(90deg, transparent, var(--accent-scan), transparent);
    transform: translateX(-120%);
  }

  .stats-lines {
    @apply pointer-events-none absolute inset-0 z-0 h-full w-full;
    overflow: visible;
  }

  .stats-lines path,
  .stats-lines circle {
    fill: none;
    stroke: var(--color-accent);
    stroke-width: 1.35;
    vector-effect: non-scaling-stroke;
  }

  .stats-lines circle {
    stroke: var(--color-border);
    stroke-dasharray: 7 10;
  }

  .stats-metrics {
    @apply relative z-10 grid gap-4 md:grid-cols-3;
  }

  .stat-card {
    @apply min-h-52 border border-border p-5 shadow-soft;
    background: var(--stat-card-bg);
    border-radius: 0.95rem;
  }

  .stat-value {
    @apply flex items-baseline gap-1 font-serif text-4xl font-bold leading-none text-text sm:text-5xl;
  }

  .stat-card h3 {
    @apply mt-5 text-sm font-bold uppercase tracking-[0.14em] text-accent-strong;
  }

  .stat-card p:last-child {
    @apply mt-3 text-sm leading-6 text-text-soft;
  }

  .stats-workflow {
    @apply relative z-10 mt-8 grid gap-3 sm:grid-cols-5;
  }

  .workflow-step {
    @apply relative flex min-h-24 items-end border border-border bg-surface px-4 py-3 shadow-line;
    border-radius: 0.85rem;
  }

  .workflow-step::before {
    content: '';
    @apply absolute left-4 top-4 h-2 w-2 rounded-full bg-accent;
  }

  .workflow-step span {
    @apply text-xs font-bold uppercase tracking-[0.16em] text-text-soft;
  }

  @media (min-width: 640px) {
    .workflow-step:not(:last-child)::after {
      content: '';
      position: absolute;
      top: 50%;
      right: -0.75rem;
      width: 0.75rem;
      height: 1px;
      background: var(--color-accent);
      opacity: 0.55;
    }
  }

  @media (max-width: 767px) {
    .stats-section {
      padding-block: 4rem;
      background-size: 3.25rem 3.25rem;
    }

    .stats-system {
      min-height: auto;
    }

    .stats-lines {
      opacity: 0.4;
    }

    .stat-card {
      min-height: auto;
    }
  }
</style>
