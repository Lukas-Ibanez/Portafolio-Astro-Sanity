---
import ArrowRight from './icons/ArrowRight.astro';

const capabilities = ['Frontend', 'Backend', 'Servidores', 'Seguridad', 'SEO'];
const chips = [
  { label: 'PHP', x: '7%', y: '16%', mx: '6%', my: '16%', tone: 'accent' },
  { label: 'JavaScript', x: '58%', y: '7%', mx: '54%', my: '10%', tone: 'sage' },
  { label: 'TypeScript', x: '73%', y: '26%', mx: '60%', my: '31%', tone: 'accent' },
  { label: 'React', x: '12%', y: '44%', mx: '7%', my: '42%', tone: 'sage' },
  { label: 'Next.js', x: '66%', y: '52%', mx: '76%', my: '45%', tone: 'text' },
  { label: 'Node.js', x: '24%', y: '70%', mx: '21%', my: '66%', tone: 'accent' },
  { label: 'WordPress', x: '56%', y: '78%', mx: '58%', my: '68%', tone: 'sage' },
  { label: 'Linux', x: '38%', y: '30%', mx: '39%', my: '29%', tone: 'text' },
  { label: 'MySQL', x: '4%', y: '78%', mx: '5%', my: '70%', tone: 'sage' },
];

const workSignals = ['Agrosuper', 'SEDUC', 'Fundación Luksic'];
---

<section class="hero-stage relative isolate overflow-hidden bg-bg" data-hero-scene>
  <div class="container-site grid min-h-[calc(100vh-4rem)] gap-10 py-10 lg:grid-cols-[0.92fr_1.08fr] lg:items-center lg:py-14">
    <div class="relative z-10">
      <div class="hero-kicker mb-7 inline-flex items-center gap-3 border border-border bg-surface px-4 py-2 text-xs font-bold uppercase tracking-[0.2em] text-text-soft shadow-line" data-hero-kicker>
        <span class="h-2 w-2 rounded-full bg-accent"></span>
        Disponible para nuevos desafíos
      </div>

      <h1 class="max-w-4xl font-serif text-[clamp(3.35rem,8.2vw,7.7rem)] leading-[0.87] text-text" aria-label="Construyo y despliego web completa.">
        <span class="hero-line" data-hero-line><span>Construyo</span></span>
        <span class="hero-line" data-hero-line><span>y despliego</span></span>
        <span class="hero-line hero-line-accent" data-hero-line><span>web completa.</span></span>
      </h1>

      <p class="hero-copy mt-8 max-w-2xl text-lg leading-8 text-text-soft sm:text-xl" data-hero-copy>
        Soy Lukas Ibáñez, desarrollador Full-Stack. Trabajo desde la lógica y la interfaz hasta el servidor Linux, seguridad, SEO y optimización. Un solo responsable técnico desde el deploy hasta el usuario final.
      </p>

      <div class="mt-8 flex flex-wrap gap-2" aria-label="Experiencia destacada">
        {
          workSignals.map((signal) => (
            <span class="hero-signal border border-border bg-surface px-3 py-2 text-xs font-semibold uppercase tracking-[0.14em] text-text-soft" data-hero-signal>
              {signal}
            </span>
          ))
        }
      </div>

      <div class="mt-10 flex flex-col gap-3 sm:flex-row">
        <a href="/proyectos/" class="hero-cta button-primary" data-hero-cta>Ver proyectos <ArrowRight /></a>
        <a href="/contacto/" class="hero-cta button-secondary" data-hero-cta>Hablemos</a>
      </div>
    </div>

    <div class="hero-system-wrap relative min-h-[34rem] lg:min-h-[42rem]" data-hero-system>
      <div class="hero-system-bg absolute inset-0 border border-border bg-surface/70"></div>

      <svg class="hero-system-lines absolute inset-0 h-full w-full" viewBox="0 0 640 640" aria-hidden="true">
        <path data-hero-path d="M320 320 C190 250 130 120 70 96" />
        <path data-hero-path d="M320 320 C430 190 500 130 570 88" />
        <path data-hero-path d="M320 320 C500 350 548 430 602 506" />
        <path data-hero-path d="M320 320 C240 450 198 540 100 584" />
        <path data-hero-path d="M320 320 C260 300 230 285 190 276" />
        <circle data-hero-ring cx="320" cy="320" r="128" />
        <circle data-hero-ring cx="320" cy="320" r="220" />
      </svg>

      <div class="hero-core absolute left-1/2 top-1/2 z-20 w-[15rem] -translate-x-1/2 -translate-y-1/2 border border-text bg-bg p-5 shadow-soft sm:w-[17rem]" data-hero-core>
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-accent-strong">Full-stack</p>
        <p class="mt-3 font-serif text-4xl leading-none text-text">Lukas Ibáñez</p>
        <p class="mt-4 text-sm leading-6 text-text-soft">código, operación y rendimiento conectados.</p>
      </div>

      {
        chips.map((chip, index) => (
          <div
            class:list={['hero-chip absolute z-30 border bg-bg px-3 py-2 text-sm font-bold shadow-line', `hero-chip-${chip.tone}`]}
            style={`--chip-x:${chip.x}; --chip-y:${chip.y}; --chip-mobile-x:${chip.mx}; --chip-mobile-y:${chip.my}; --chip-index:${index};`}
            data-hero-chip
          >
            {chip.label}
          </div>
        ))
      }

      <div class="hero-stack absolute bottom-0 left-0 right-0 z-20 grid border-t border-border bg-bg/92 backdrop-blur sm:grid-cols-5">
        {
          capabilities.map((item) => (
            <div class="hero-capability border-b border-border px-4 py-4 text-center sm:border-b-0 sm:border-r last:sm:border-r-0" data-hero-capability>
              <span class="block text-[0.68rem] font-bold uppercase tracking-[0.18em] text-text-soft">{item}</span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
