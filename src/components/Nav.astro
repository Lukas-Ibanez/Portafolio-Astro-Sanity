---
const links = [
  { href: '/', label: 'Inicio' },
  { href: '/proyectos/', label: 'Proyectos' },
  { href: '/blog/', label: 'Blog' },
  { href: '/contacto/', label: 'Contacto' },
];
const currentPath = Astro.url.pathname;
---

<header id="site-header" class="site-header" data-site-header>
  <nav id="main-navigation" class="main-nav" aria-label="Principal">
    <a href="/" class="brand-link" aria-label="Ir al inicio">
      Lukas Ibáñez
    </a>

    <div class="desktop-nav">
      {
        links.map((link) => {
          const isActive = link.href === '/' ? currentPath === '/' : currentPath.startsWith(link.href);
          return (
            <a
              href={link.href}
              aria-current={isActive ? 'page' : undefined}
              class:list={[
                'desktop-nav-link',
                isActive && 'is-active',
              ]}
            >
              {link.label}
            </a>
          );
        })
      }
    </div>

    <div class="nav-end">
      <!-- Dark mode toggle -->
      <button
        type="button"
        class="theme-toggle"
        aria-label="Cambiar tema"
        data-theme-toggle
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg class="theme-icon theme-icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"/>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg class="theme-icon theme-icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
        </svg>
      </button>

      <button
        type="button"
        class="hamburger-button"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-menu"
        data-menu-button
      >
        <span class="sr-only">Abrir menú</span>
        <span class="hamburger-lines" aria-hidden="true">
          <span></span>
          <span></span>
          <span></span>
        </span>
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="mobile-menu" data-mobile-menu hidden>
    <div class="mobile-menu-list">
      {
        links.map((link) => {
          const isActive = link.href === '/' ? currentPath === '/' : currentPath.startsWith(link.href);
          return (
            <a
              href={link.href}
              aria-current={isActive ? 'page' : undefined}
              class:list={[
                'mobile-menu-link',
                isActive && 'is-active',
              ]}
              data-mobile-link
            >
              {link.label}
            </a>
          );
        })
      }
    </div>
  </div>
</header>

<style>
  .site-header {
    @apply sticky top-0 z-40 border-b backdrop-blur;
    background: var(--nav-bg);
    border-color: var(--nav-border);
  }

  .main-nav {
    @apply mx-auto flex min-h-16 w-full max-w-site items-center justify-between gap-6 px-5 sm:px-8;
  }

  .brand-link {
    @apply font-serif text-xl text-text no-underline;
  }

  .desktop-nav {
    @apply hidden items-center gap-1 rounded-full border border-border bg-surface p-1 text-sm shadow-line md:flex;
  }

  .desktop-nav-link {
    @apply rounded-full px-4 py-2 font-medium text-text-soft no-underline transition hover:text-text;
  }

  .desktop-nav-link.is-active {
    @apply bg-accent-soft text-text;
  }

  .nav-end {
    @apply flex items-center gap-2;
  }

  /* ─── Theme toggle ──────────────────────────────────────── */
  .theme-toggle {
    @apply inline-flex size-11 items-center justify-center rounded-full border border-border bg-surface text-text shadow-line;
    transition: background-color 0.2s, border-color 0.2s, color 0.2s;
  }

  .theme-toggle:hover {
    border-color: var(--color-accent);
    color: var(--color-accent-strong);
  }

  .theme-icon {
    transition: opacity 0.2s, transform 0.3s;
  }

  /* Light mode: show moon, hide sun */
  :root:not([data-theme="dark"]) .theme-icon-sun,
  [data-theme="light"] .theme-icon-sun {
    display: none;
  }

  /* Dark mode: show sun, hide moon */
  [data-theme="dark"] .theme-icon-moon {
    display: none;
  }

  /* ─── Hamburger ─────────────────────────────────────────── */
  .hamburger-button {
    @apply inline-flex size-11 items-center justify-center rounded-full border border-border bg-surface text-text shadow-line md:hidden;
  }

  .hamburger-lines {
    display: grid;
    gap: 4px;
    width: 18px;
  }

  .hamburger-lines span {
    display: block;
    height: 2px;
    border-radius: 999px;
    background: var(--color-text);
    transform-origin: center;
    transition: transform 180ms ease, opacity 180ms ease;
  }

  .hamburger-button.is-open .hamburger-lines span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .hamburger-button.is-open .hamburger-lines span:nth-child(2) {
    opacity: 0;
  }

  .hamburger-button.is-open .hamburger-lines span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  .mobile-menu {
    @apply border-t border-border px-5 py-4 shadow-soft backdrop-blur md:hidden;
    background: var(--mobile-menu-bg);
    animation: mobile-menu-in 180ms ease both;
  }

  .mobile-menu-list {
    @apply grid gap-2;
  }

  .mobile-menu-link {
    @apply rounded-xl border border-border bg-surface px-4 py-3 text-sm font-semibold text-text-soft no-underline transition hover:text-text;
  }

  .mobile-menu-link.is-active {
    @apply border-accent-soft bg-accent-soft text-text;
  }

  @keyframes mobile-menu-in {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  /* ─── Mobile menu ─────────────────────────────────────────── */
  const header = document.querySelector('[data-site-header]');
  const button = header?.querySelector<HTMLButtonElement>('[data-menu-button]');
  const menu = header?.querySelector<HTMLElement>('[data-mobile-menu]');
  const links = header?.querySelectorAll('[data-mobile-link]');

  function setOpen(isOpen: boolean) {
    if (!button || !menu) return;
    button.setAttribute('aria-expanded', String(isOpen));
    button.setAttribute('aria-label', isOpen ? 'Cerrar menú' : 'Abrir menú');
    button.classList.toggle('is-open', isOpen);
    menu.hidden = !isOpen;
    menu.classList.toggle('is-open', isOpen);
  }

  button?.addEventListener('click', () => {
    setOpen(button.getAttribute('aria-expanded') !== 'true');
  });

  links?.forEach((link) => {
    link.addEventListener('click', () => setOpen(false));
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth >= 768) setOpen(false);
  });

  /* ─── Dark mode toggle ────────────────────────────────────── */
  const themeToggle = document.querySelector<HTMLButtonElement>('[data-theme-toggle]');
  const html = document.documentElement;
  const themeMeta = document.getElementById('theme-color-meta');

  function applyTheme(theme: string) {
    html.setAttribute('data-theme', theme);
    localStorage.setItem('theme', theme);
    if (themeMeta) {
      themeMeta.setAttribute('content', theme === 'dark' ? '#1A1815' : '#F7F4EE');
    }
    themeToggle?.setAttribute('aria-label', theme === 'dark' ? 'Cambiar a modo claro' : 'Cambiar a modo oscuro');
  }

  themeToggle?.addEventListener('click', () => {
    const current = html.getAttribute('data-theme') ?? 'light';
    applyTheme(current === 'dark' ? 'light' : 'dark');
  });

  // Sync initial aria-label
  const initialTheme = html.getAttribute('data-theme') ?? 'light';
  themeToggle?.setAttribute('aria-label', initialTheme === 'dark' ? 'Cambiar a modo claro' : 'Cambiar a modo oscuro');
</script>
