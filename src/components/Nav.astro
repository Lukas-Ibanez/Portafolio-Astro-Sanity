---
const links = [
  { href: '/', label: 'Inicio' },
  { href: '/proyectos/', label: 'Proyectos' },
  { href: '/blog/', label: 'Blog' },
  { href: '/contacto/', label: 'Contacto' },
];
const currentPath = Astro.url.pathname;
---

<header id="site-header" class="site-header" data-site-header>
  <nav id="main-navigation" class="main-nav" aria-label="Principal">
    <a href="/" class="brand-link" aria-label="Ir al inicio">
      Lukas Ibáñez
    </a>

    <div class="desktop-nav">
      {
        links.map((link) => {
          const isActive = link.href === '/' ? currentPath === '/' : currentPath.startsWith(link.href);
          return (
            <a
              href={link.href}
              aria-current={isActive ? 'page' : undefined}
              class:list={[
                'desktop-nav-link',
                isActive && 'is-active',
              ]}
            >
              {link.label}
            </a>
          );
        })
      }
    </div>

    <button
      type="button"
      class="hamburger-button"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="mobile-menu"
      data-menu-button
    >
      <span class="sr-only">Abrir menú</span>
      <span class="hamburger-lines" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </button>
  </nav>

  <div id="mobile-menu" class="mobile-menu" data-mobile-menu hidden>
    <div class="mobile-menu-list">
      {
        links.map((link) => {
          const isActive = link.href === '/' ? currentPath === '/' : currentPath.startsWith(link.href);
          return (
            <a
              href={link.href}
              aria-current={isActive ? 'page' : undefined}
              class:list={[
                'mobile-menu-link',
                isActive && 'is-active',
              ]}
              data-mobile-link
            >
              {link.label}
            </a>
          );
        })
      }
    </div>
  </div>
</header>

<style>
  .site-header {
    @apply sticky top-0 z-40 border-b backdrop-blur;
    background: rgba(247, 244, 238, 0.9);
    border-color: rgba(227, 221, 209, 0.8);
  }

  .main-nav {
    @apply mx-auto flex min-h-16 w-full max-w-site items-center justify-between gap-6 px-5 sm:px-8;
  }

  .brand-link {
    @apply font-serif text-xl text-text no-underline;
  }

  .desktop-nav {
    @apply hidden items-center gap-1 rounded-full border border-border bg-surface p-1 text-sm shadow-line md:flex;
  }

  .desktop-nav-link {
    @apply rounded-full px-4 py-2 font-medium text-text-soft no-underline transition hover:text-text;
  }

  .desktop-nav-link.is-active {
    @apply bg-accent-soft text-text;
  }

  .hamburger-button {
    @apply inline-flex size-11 items-center justify-center rounded-full border border-border bg-surface text-text shadow-line md:hidden;
  }

  .hamburger-lines {
    display: grid;
    gap: 4px;
    width: 18px;
  }

  .hamburger-lines span {
    display: block;
    height: 2px;
    border-radius: 999px;
    background: var(--color-text);
    transform-origin: center;
    transition: transform 180ms ease, opacity 180ms ease;
  }

  .hamburger-button.is-open .hamburger-lines span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }

  .hamburger-button.is-open .hamburger-lines span:nth-child(2) {
    opacity: 0;
  }

  .hamburger-button.is-open .hamburger-lines span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }

  .mobile-menu {
    @apply border-t border-border px-5 py-4 shadow-soft backdrop-blur md:hidden;
    background: rgba(247, 244, 238, 0.95);
    animation: mobile-menu-in 180ms ease both;
  }

  .mobile-menu-list {
    @apply grid gap-2;
  }

  .mobile-menu-link {
    @apply rounded-xl border border-border bg-surface px-4 py-3 text-sm font-semibold text-text-soft no-underline transition hover:text-text;
  }

  .mobile-menu-link.is-active {
    @apply border-accent-soft bg-accent-soft text-text;
  }

  @keyframes mobile-menu-in {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  const header = document.querySelector('[data-site-header]');
  const button = header?.querySelector<HTMLButtonElement>('[data-menu-button]');
  const menu = header?.querySelector<HTMLElement>('[data-mobile-menu]');
  const links = header?.querySelectorAll('[data-mobile-link]');

  function setOpen(isOpen: boolean) {
    if (!button || !menu) return;
    button.setAttribute('aria-expanded', String(isOpen));
    button.setAttribute('aria-label', isOpen ? 'Cerrar menú' : 'Abrir menú');
    button.classList.toggle('is-open', isOpen);
    menu.hidden = !isOpen;
    menu.classList.toggle('is-open', isOpen);
  }

  button?.addEventListener('click', () => {
    setOpen(button.getAttribute('aria-expanded') !== 'true');
  });

  links?.forEach((link) => {
    link.addEventListener('click', () => setOpen(false));
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth >= 768) setOpen(false);
  });
</script>
